      "prompt": "$",
      "steps": [
        {
          "kind": "out",
          "text": "const frame = useCurrentFrame();   // 现在第几帧"
        },
        {
          "kind": "out",
          "text": "// 按帧号算这帧该画成什么样：位置/透明度/大小"
        },
        {
          "kind": "out",
          "text": "const opacity = interpolate(frame, [0, 30], [0, 1]);"
        },
        {
          "kind": "out",
          "text": "// 30fps：你按秒想，引擎按帧算"
        },
        {
          "kind": "out",
          "text": "// 第 3 秒 = 第 90 帧，不用一帧帧手摆"
        }
      ]
